# Q1. Count Lines in a File
def CountLines(filename):
    file = open(filename, "r")
 
    count = 0
 
    for line in file:
        count += 1
 
    file.close()
 
    return count
 
 
def main():
    name = input("Enter file name: ")
 
    result = CountLines(name)
 
    print("Total number of lines:", result)
 
 
if __name__ == "__main__":
    main()